<link rel="stylesheet" href="/styles/dashboard.css">

<div class="dashboard">

  <div class="card">
    <p class="section-title">Host</p>
    <div class="host-body">

      <div class="rings-container">
        <% hostRings.forEach(r => { %>
          <div class="ring-item">
            <div class="ring-chart" style="--ring-percent:<%= r.pct %>;--ring-color:<%= r.color %>;">
              <svg viewBox="-50 -50 100 100">
                <circle cx="0" cy="0"/>
                <circle cx="0" cy="0" class="ring-fill"/>
              </svg>
              <span class="ring-label"><%= r.pct %>%</span>
            </div>
            <span class="ring-item-label"><%= r.label %></span>
          </div>
        <% }) %>
      </div>

      <div class="host-meta">
        <% hostMeta.forEach(m => { %>
          <div class="meta-row">
            <span class="meta-label"><%= m.label %></span>
            <span class="meta-value"><%= m.value %></span>
          </div>
        <% }) %>
      </div>

    </div>
  </div>

  <div class="card">
    <p class="section-title">Containers</p>
    <div class="servers-row">

      <div class="ring-item">
        <div class="ring-chart" style="--ring-percent:<%= serverRing.pct %>;--ring-color:<%= serverRing.color %>;">
          <svg viewBox="-50 -50 100 100">
            <circle cx="0" cy="0"/>
            <circle cx="0" cy="0" class="ring-fill"/>
          </svg>
          <div class="ring-label ring-label--stack">
            <span class="ring-label-main"><%= serverRing.running %>/<%= serverRing.total %></span>
          </div>
        </div>
        <span class="ring-item-label">Running</span>
      </div>

      <div class="server-list">
        <% serversStats.servers.forEach(server => { %>
          <div class="server-row">
            <div class="server-dot"></div>
            <span class="server-name"><%= server.name %></span>
            <span class="server-status"><%= server.status %></span>
          </div>
        <% }) %>
      </div>

    </div>
  </div>

</div>