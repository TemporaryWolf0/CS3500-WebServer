<div class="nav-heading">Servers</div>

<% servers.forEach(function(server) {
  const id = server.id;
  const status = server.status || 'unknown';
  const active = currentServerId === id ? 'active' : '';
%>
  <a class="nav-item <%= active %>" href="/servers/server-manager/<%= id %>">
    <div class="status-dot status-dot--<%= status %>"></div>
    <span><%= server.name %></span>
  </a>
<% }) %>

<a class="new-server-btn" href="/servers/server-manager/new">
  <div class="btn-plus">+</div>
  <span>New server</span>
</a>
