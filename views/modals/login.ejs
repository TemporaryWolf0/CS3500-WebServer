<link href="/styles/modal.css" rel="stylesheet"/>
<link href="/styles/form.css" rel="stylesheet"/>
<div class="modal" id="loginModal">
  <div class="modal-content">
    <span class="close" onclick="document.getElementById('loginModal').style.display='none'">&times;</span>
    <div class="profile-imgContainer">
      <img src="/images/profile.png" class="profile-img" alt="Profile Image">
    </div>
    <form method="POST" action="/auth/login">
      <label>Username<br/><input type="text" name="username" required/></label><br/>
      <label>Password<br/><input type="password" name="password" required/></label><br/>
      <button type="submit" class="btn btn-good btn-full">Login</button>
    </form>
  </div>
</div>
