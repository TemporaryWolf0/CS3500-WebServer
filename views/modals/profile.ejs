<link href="/styles/modal.css" rel="stylesheet"/>
<link rel="stylesheet" href="/styles/form.css">
<div class="modal" id="profileModal">
  <div class="modal-content">
    <span class="close" onclick="document.getElementById('profileModal').style.display='none'">&times;</span>
    <h2>Your Profile</h2>

    <form action="/auth/profile-update" method="POST">
      <input type="hidden" name="origUsername" value="<%= currentUser.username %>">
      
      <label>Name</label>
      <input type="text" name="name" value="<%= currentUser.name || '' %>">

      <label>Username</label>
      <input type="text" name="username" value="<%= currentUser.username || '' %>">

      <label>Email</label>
      <input type="text" name="email" value="<%= currentUser.email || '' %>">

      <label>Phone</label>
      <input type="text" name="phone" value="<%= currentUser.phone || '' %>">

      <button type="submit" class="btn btn-good btn-full">Update Profile</button>
    </form>

    <div class="btn-actions">
      <a class="btn-alt btn-neutral" href="/auth/logout">Logout</a>

      <form id="deleteForm" action="/auth/profile-delete" method="POST" onsubmit="return confirm('Are you sure you want to delete your account? This cannot be undone.');">
        <button class="btn-alt btn-danger" type="submit">Delete Account</button>
      </form>
    </div>
  </div>
</div>
